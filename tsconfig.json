{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": false,
    "isolatedModules": true,
    "lib": ["ES2022"]
  },
  "include": ["*.ts", "test/**/*.ts"]
}
